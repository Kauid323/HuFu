<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HuFu.Pages.InfoRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:HuFu.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <FontIcon Glyph="{x:Bind Icon, Mode=OneWay}" 
                  FontSize="18" 
                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                  VerticalAlignment="Center" />

        <TextBlock Grid.Column="1" 
                   Text="{x:Bind Label, Mode=OneWay}" 
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="{x:Bind Value, Mode=OneWay}" 
                       IsTextSelectionEnabled="True" 
                       FontWeight="Medium" />
            <TextBlock Text="{x:Bind SubValue, Mode=OneWay}" 
                       FontSize="12" 
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       Visibility="{x:Bind SubValue, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <Button Grid.Column="3" 
                Visibility="{x:Bind IsCopyable, Mode=OneWay}"
                Style="{StaticResource SubtleButtonStyle}"
                Click="CopyButton_Click"
                ToolTipService.ToolTip="复制">
            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
        </Button>
    </Grid>
</UserControl>
