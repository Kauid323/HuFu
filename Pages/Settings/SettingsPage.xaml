<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HuFu.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HuFu.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="设置" FontSize="28" FontWeight="Bold" />

            <StackPanel Spacing="8">
                <TextBlock Text="发送快捷键" FontSize="16" FontWeight="SemiBold" />
                <ComboBox x:Name="ShortcutComboBox" 
                          HorizontalAlignment="Left" 
                          Width="200"
                          SelectionChanged="ShortcutComboBox_SelectionChanged">
                    <ComboBoxItem Content="Enter" Tag="Enter" />
                    <ComboBoxItem Content="Ctrl + Enter" Tag="CtrlEnter" />
                </ComboBox>
                <TextBlock Text="设置发送消息时使用的组合键。" 
                           FontSize="12" 
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>

            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="侧边栏导航" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="恢复默认" Click="ResetNavigation_Click" />
                </Grid>
                <TextBlock Text="拖动项目可以调整顺序，使用开关控制显示/隐藏。" 
                           FontSize="12" 
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                
                <ListView x:Name="NavigationItemsList"
                          ItemsSource="{x:Bind ViewModel.NavigationItems, Mode=OneWay}"
                          SelectionMode="None"
                          CanReorderItems="True"
                          AllowDrop="True"
                          ReorderMode="Enabled"
                          Margin="0,8,0,0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:NavigationItemViewModel">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Glyph="&#xE700;" FontSize="16" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                
                                <TextBlock Grid.Column="1" Text="{x:Bind Title, Mode=OneWay}" VerticalAlignment="Center" />
                                
                                <ToggleSwitch Grid.Column="2" 
                                              IsOn="{x:Bind IsVisible, Mode=TwoWay}" 
                                              OnContent="" 
                                              OffContent=""
                                              MinWidth="40" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
