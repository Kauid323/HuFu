<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HuFu.Controls.ChatInputControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" 
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          PointerPressed="RootGrid_PointerPressed"
          MinHeight="48"
          MaxHeight="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 拖拽调大小的边缘热区 -->
        <Rectangle x:Name="ResizeHandle"
                   Height="4"
                   Fill="Transparent"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Stretch"
                   PointerEntered="ResizeHandle_PointerEntered"
                   PointerExited="ResizeHandle_PointerExited"
                   PointerPressed="ResizeHandle_PointerPressed"
                   PointerMoved="ResizeHandle_PointerMoved"
                   PointerReleased="ResizeHandle_PointerReleased" />

        <!-- 功能按钮栏 -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Spacing="4" 
                    Padding="8,4"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Button MinWidth="32" MinHeight="32" Padding="4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="发送文件">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                    </StackPanel>
                </Button.Content>
            </Button>
            
            <Button MinWidth="32" MinHeight="32" Padding="4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="发送图片">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xEB9F;" FontSize="16" />
                    </StackPanel>
                </Button.Content>
            </Button>
            
            <Button MinWidth="32" MinHeight="32" Padding="4" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="表情">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE76E;" FontSize="16" />
                    </StackPanel>
                </Button.Content>
            </Button>

            <TextBlock Text="TODO: 功能待实现" 
                       FontSize="11" 
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
        </StackPanel>

        <RichEditBox x:Name="InputBox"
                     Grid.Row="2"
                     Padding="12,8"
                     PlaceholderText="输入消息…"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     MinHeight="32"
                     PreviewKeyDown="InputBox_PreviewKeyDown">
            <RichEditBox.Resources>
                <!-- 彻底移除所有状态下的边框、背景、圆角和阴影 -->
                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
                
                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
                
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent" />
            </RichEditBox.Resources>
        </RichEditBox>
    </Grid>
</UserControl>
